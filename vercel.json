{
    "version": 2,
    "cleanUrls": true,
    "rewrites": [
        { "source": "/", "destination": "/frontend/index.html" },
        { "source": "/index.html", "destination": "/frontend/index.html" },
        { "source": "/about", "destination": "/frontend/about.html" },
        { "source": "/history", "destination": "/frontend/history.html" },
        { "source": "/result", "destination": "/frontend/result.html" },
        { "source": "/static/(.*)", "destination": "/frontend/static/$1" },
        { "source": "/(.*)", "destination": "/frontend/$1" }
    ]
}
